{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Juni IDE",
  "version": "11.0.0",
  "identifier": "dev.juni.desktop",
  "build": {
    "beforeDevCommand": "cd ../ide && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:ide",
    "frontendDist": "../../ide/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Juni IDE",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi", "appimage", "deb"],
    "category": "DeveloperTool",
    "shortDescription": "Juni language IDE",
    "longDescription": "Desktop shell for the Juni IDE: native project filesystem, LSP, and the same Vite + Monaco authoring experience as the web app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
