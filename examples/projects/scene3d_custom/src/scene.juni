export fn setup() -> i32:
    scene3d_init(640, 360)
    cam = camera3d_perspective(60.0, 1.777, 0.1, 100.0)
    box = mesh3d_box(1.2, 0.6, 0.8)
    mesh3d_set_pose(box, 0.0, 0.0, -5.0, 0.2, 0.4, 0.0)
    return 0

export fn render(dt: f32) -> i32:
    scene3d_clear(0.05, 0.06, 0.1, 1.0)
    mesh3d_rotate(box, dt * 0.5, dt * 0.8, dt * 0.2)
    scene3d_draw(box, cam)
    return 0

state:
    cam: i32 = 0
    box: i32 = 0
