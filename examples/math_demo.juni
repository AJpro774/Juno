fn main() -> i32:
    print("pow(2,10):")
    print(pow(2.0, 10.0))
    print("pi:")
    print(pi())
    print("dist2(3,4):")
    print(dist2(0.0, 0.0, 3.0, 4.0))
    print("smoothstep:")
    print(smoothstep(0.0, 1.0, 0.5))
    print("str_concat:")
    print(str_concat("Juni ", "v4"))
    print("iclamp(99,0,10):")
    print(iclamp(99, 0, 10))
    print("sin(1):")
    print(sin(1.0))
    print("clamp/lerp:")
    print(clamp(5.0, 0.0, 3.0))
    print(lerp(0.0, 10.0, 0.5))
    return 0
